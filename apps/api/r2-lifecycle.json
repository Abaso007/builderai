{
  "rules": [
    {
      "id": "delete-raw-after-7-days",
      "enabled": true,
      "conditions": { "prefix": "lakehouse/raw/" },
      "deleteObjectsTransition": { "condition": { "maxAge": 7, "type": "Age" } }
    },
    {
      "id": "delete-compacted-after-retention",
      "enabled": true,
      "conditions": { "prefix": "lakehouse/compacted/" },
      "deleteObjectsTransition": { "condition": { "maxAge": 365, "type": "Age" } }
    },
    {
      "id": "abort-incomplete-multipart-7-days",
      "enabled": true,
      "abortMultipartUploadsTransition": { "condition": { "maxAge": 7, "type": "Age" } }
    }
  ]
}
