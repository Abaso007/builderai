{
  "Rules": [
    {
      "ID": "delete-raw-after-compaction",
      "Status": "Disabled",
      "Filter": {
        "Prefix": "lakehouse/"
      },
      "Expiration": {
        "Days": 7
      },
      "NoncurrentVersionExpiration": {
        "NoncurrentDays": 1
      }
    },
    {
      "ID": "delete-compacted-after-retention",
      "Status": "Enabled",
      "Filter": {
        "Prefix": "lakehouse/"
      },
      "Expiration": {
        "Days": 365
      }
    },
    {
      "ID": "abort-incomplete-multipart",
      "Status": "Enabled",
      "AbortIncompleteMultipartUpload": {
        "DaysAfterInitiation": 7
      }
    }
  ]
}
