/**
 * For more details on how to configure Wrangler, refer to:
 * https://developers.cloudflare.com/workers/wrangler/configuration/
 */
{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "api",
  "main": "src/index.ts",
  "compatibility_date": "2025-03-19",
  "compatibility_flags": ["nodejs_compat", "nodejs_compat_populate_process_env"],
  "env": {
    "prod": {
      "observability": {
        "enabled": true,
        "head_sampling_rate": 0.1 // 10% of requests
      },
      "route": {
        "pattern": "api.unprice.dev",
        "custom_domain": true
      },
      "r2_buckets": [
        {
          "binding": "LAKEHOUSE",
          "bucket_name": "unprice-lakehouse-prod"
        }
      ],
      "vars": {
        "LAKEHOUSE_FILE_PLAN_BASE_URL": "https://unprice-lakehouse-api.fly.dev"
      },
      "unsafe": {
        "bindings": [
          {
            "name": "RL_FREE_1000_60s",
            "type": "ratelimit",
            "namespace_id": "1001",
            "simple": {
              "limit": 1000,
              "period": 60
            }
          },
          {
            "name": "RL_FREE_6000_60s",
            "type": "ratelimit",
            "namespace_id": "1002",
            "simple": {
              "limit": 6000, // 100 requests per second
              "period": 60
            }
          }
        ]
      },
      "pipelines": [
        {
          "pipeline": "09e14fee72ab4b7c85a3dd67ced13f72",
          "binding": "PIPELINE_VERIFICATIONS"
        },
        {
          "pipeline": "09e14fee72ab4b7c85a3dd67ced13f72",
          "binding": "PIPELINE_USAGE"
        },
        {
          "pipeline": "09e14fee72ab4b7c85a3dd67ced13f72",
          "binding": "PIPELINE_METADATA"
        },
        {
          "pipeline": "09e14fee72ab4b7c85a3dd67ced13f72",
          "binding": "PIPELINE_ENTITLEMENTS"
        }
      ],
      "durable_objects": {
        "bindings": [
          {
            "name": "usagelimit",
            "class_name": "DurableObjectUsagelimiter"
          },
          {
            "name": "projectdo",
            "class_name": "DurableObjectProject"
          }
        ]
      },
      "migrations": [
        {
          "tag": "v1",
          "new_sqlite_classes": ["DurableObjectUsagelimiter"]
        },
        {
          "tag": "v2",
          "new_sqlite_classes": ["DurableObjectProject"]
        }
      ]
    },
    "preview": {
      "observability": {
        "enabled": true,
        "head_sampling_rate": 1.0 // 100% of requests
      },
      "route": {
        "pattern": "preview-api.unprice.dev",
        "custom_domain": true
      },
      "r2_buckets": [
        {
          "binding": "LAKEHOUSE",
          "bucket_name": "unprice-lakehouse-dev"
        }
      ],
      "vars": {
        "LAKEHOUSE_FILE_PLAN_BASE_URL": "https://unprice-lakehouse-api.fly.dev"
      },
      "unsafe": {
        // # Limit: the number of tokens allowed within a given period in a single
        // # Cloudflare location
        // # Period: the duration of the period, in seconds. Must be either 10 or 60
        "bindings": [
          {
            "name": "RL_FREE_1000_60s",
            "type": "ratelimit",
            "namespace_id": "1001",
            "simple": {
              "limit": 1000,
              "period": 60
            }
          },
          {
            "name": "RL_FREE_6000_60s",
            "type": "ratelimit",
            "namespace_id": "1002",
            "simple": {
              "limit": 6000, // 100 requests per second
              "period": 60
            }
          }
        ]
      },
      "pipelines": [
        {
          "pipeline": "75cfca9093854dd88f4d46e2088f235b",
          "binding": "PIPELINE_VERIFICATIONS",
          "remote": true
        },
        {
          "pipeline": "a636dd5b2ca3485aab7de834efccf099",
          "binding": "PIPELINE_USAGE",
          "remote": true
        },
        {
          "pipeline": "c0c1af506adb4e0c9394dde8e0c66241",
          "binding": "PIPELINE_METADATA",
          "remote": true
        },
        {
          "pipeline": "ac1eb44429dc40f9992d38e5daff6c6c",
          "binding": "PIPELINE_ENTITLEMENTS",
          "remote": true
        }
      ],
      "durable_objects": {
        "bindings": [
          {
            "name": "usagelimit",
            "class_name": "DurableObjectUsagelimiter"
          },
          {
            "name": "projectdo",
            "class_name": "DurableObjectProject"
          }
        ]
      },
      "migrations": [
        {
          "tag": "v1",
          "new_sqlite_classes": ["DurableObjectUsagelimiter"]
        },
        {
          "tag": "v2",
          "new_sqlite_classes": ["DurableObjectProject"]
        }
      ]
    },
    "dev": {
      "r2_buckets": [
        {
          "binding": "LAKEHOUSE",
          "bucket_name": "unprice-lakehouse-dev",
          "remote": true
        }
      ],
      "vars": {
        "LAKEHOUSE_FILE_PLAN_BASE_URL": "https://unprice-lakehouse-api.fly.dev"
      },
      "unsafe": {
        // # Limit: the number of tokens allowed within a given period in a single
        // # Cloudflare location
        // # Period: the duration of the period, in seconds. Must be either 10 or 60
        "bindings": [
          {
            "name": "RL_FREE_1000_60s",
            "type": "ratelimit",
            "namespace_id": "1001",
            "simple": {
              "limit": 1000,
              "period": 60
            }
          },
          {
            "name": "RL_FREE_6000_60s",
            "type": "ratelimit",
            "namespace_id": "1002",
            "simple": {
              "limit": 6000, // 100 requests per second
              "period": 60
            }
          }
        ]
      },
      "durable_objects": {
        "bindings": [
          {
            "name": "usagelimit",
            "class_name": "DurableObjectUsagelimiter"
          },
          {
            "name": "projectdo",
            "class_name": "DurableObjectProject"
          }
        ]
      },
      "pipelines": [
        {
          "pipeline": "75cfca9093854dd88f4d46e2088f235b",
          "binding": "PIPELINE_VERIFICATIONS",
          "remote": true
        },
        {
          "pipeline": "a636dd5b2ca3485aab7de834efccf099",
          "binding": "PIPELINE_USAGE",
          "remote": true
        },
        {
          "pipeline": "c0c1af506adb4e0c9394dde8e0c66241",
          "binding": "PIPELINE_METADATA",
          "remote": true
        },
        {
          "pipeline": "ac1eb44429dc40f9992d38e5daff6c6c",
          "binding": "PIPELINE_ENTITLEMENTS",
          "remote": true
        }
      ],
      "migrations": [
        {
          "tag": "v1",
          "new_sqlite_classes": ["DurableObjectUsagelimiter"]
        },
        {
          "tag": "v2",
          "new_sqlite_classes": ["DurableObjectProject"]
        }
      ]
    }
  },
  "rules": [
    {
      "type": "Text",
      "globs": ["**/*.sql"],
      "fallthrough": true
    }
  ]
  // disable smart placement for now
  // "placement": {
  //   "mode": "smart"
  // },
  /**
   * Smart Placement
   * Docs: https://developers.cloudflare.com/workers/configuration/smart-placement/#smart-placement
   */
  // "placement": { "mode": "smart" },
  /**
   * Bindings
   * Bindings allow your Worker to interact with resources on the Cloudflare Developer Platform, including
   * databases, object storage, AI inference, real-time communication and more.
   * https://developers.cloudflare.com/workers/runtime-apis/bindings/
   */
  /**
   * Environment Variables
   * https://developers.cloudflare.com/workers/wrangler/configuration/#environment-variables
   */
  // "vars": { "MY_VARIABLE": "production_value" },
  /**
   * Note: Use secrets to store sensitive data.
   * https://developers.cloudflare.com/workers/configuration/secrets/
   */
  /**
   * Static Assets
   * https://developers.cloudflare.com/workers/static-assets/binding/
   */
  // "assets": { "directory": "./public/", "binding": "ASSETS" },
  /**
   * Service Bindings (communicate between multiple Workers)
   * https://developers.cloudflare.com/workers/wrangler/configuration/#service-bindings
   */
  // "services": [{ "binding": "MY_SERVICE", "service": "my-service" }]
}
