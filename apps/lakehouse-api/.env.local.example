ENV=dev
LAKEHOUSE_API_TOKEN=dev-token
CATALOG=unprice-lakehouse-dev
CATALOG_NAMESPACE=lakehouse
LAKEHOUSE_BUCKET_NAME=unprice-lakehouse-dev

# Required Cloudflare credentials
CLOUDFLARE_ACCOUNT_ID=
CATALOG_TOKEN=
CLOUDFLARE_API_TOKEN_LAKEHOUSE=
CLOUDFLARE_LAKEHOUSE_ACCESS_KEY_ID=

# Optional SWR cache tuning
LAKEHOUSE_RESPONSE_CACHE_SWR_SECONDS=300
LAKEHOUSE_RESPONSE_CACHE_STALE_SECONDS=3300
LAKEHOUSE_RESPONSE_CACHE_MAX_ENTRIES=512
